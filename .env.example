OPENAI_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=kosik-workshop

# environment: development | production
# Controls which commit tag the Košík prompt loader pulls from LangSmith Hub.
ENVIRONMENT=development

# Optional: pin a specific prompt commit hash (overrides ENVIRONMENT).
# KOSIK_PROMPT_COMMIT=
